<Window x:Class="PlSqlAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:cv="clr-namespace:PlSqlAnalyzer.Converters"
        xmlns:vm="clr-namespace:PlSqlAnalyzer.ViewModels"
        Title="PL/SQL Analyzer  —  Oracle Package / Procedure / Function 분석기"
        Height="900" Width="1520" MinHeight="600" MinWidth="900"
        Background="#1E1E1E" Foreground="#D4D4D4"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

  <Window.Resources>
    <cv:BoolToVis      x:Key="BoolToVis"/>
    <cv:BoolToVisInv   x:Key="BoolToVisInv"/>
    <cv:NullToVis      x:Key="NullToVis"/>
    <cv:StringToColor  x:Key="StrToColor"/>
    <cv:DeadCodeColor  x:Key="DeadColor"/>
    <cv:CallResolvedColor x:Key="CallColor"/>
    <cv:UnusedVarColor x:Key="UnusedColor"/>

    <SolidColorBrush x:Key="Bg0"    Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Bg1"    Color="#252526"/>
    <SolidColorBrush x:Key="Bg2"    Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Bg3"    Color="#3C3C3C"/>
    <SolidColorBrush x:Key="Acc"    Color="#007ACC"/>
    <SolidColorBrush x:Key="Txt"    Color="#D4D4D4"/>
    <SolidColorBrush x:Key="TxtMut" Color="#808080"/>
    <SolidColorBrush x:Key="Sel"    Color="#264F78"/>

    <!-- ScrollBar -->
    <Style TargetType="ScrollBar">
      <Setter Property="Background" Value="#252526"/>
      <Setter Property="Foreground" Value="#424242"/>
    </Style>

    <!-- ListBox -->
    <Style TargetType="ListBox">
      <Setter Property="Background" Value="#252526"/>
      <Setter Property="Foreground" Value="#D4D4D4"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="ListBoxItem">
      <Setter Property="Padding" Value="4,2"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#264F78"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2D2E"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#3C3C3C"/>
      <Setter Property="Foreground" Value="#D4D4D4"/>
      <Setter Property="BorderBrush" Value="#555555"/>
      <Setter Property="CaretBrush" Value="#D4D4D4"/>
      <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Button -->
    <Style TargetType="Button">
      <Setter Property="Background"  Value="#3C3C3C"/>
      <Setter Property="Foreground"  Value="#D4D4D4"/>
      <Setter Property="BorderBrush" Value="#555555"/>
      <Setter Property="Padding"     Value="8,3"/>
      <Setter Property="Cursor"      Value="Hand"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#505050"/>
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#007ACC"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- TreeView -->
    <Style TargetType="TreeView">
      <Setter Property="Background" Value="#252526"/>
      <Setter Property="Foreground" Value="#D4D4D4"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
    </Style>
    <Style TargetType="TreeViewItem">
      <Setter Property="Foreground"  Value="#D4D4D4"/>
      <Setter Property="Padding"     Value="2,1"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#264F78"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2D2E"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
      <Setter Property="Background"           Value="#252526"/>
      <Setter Property="Foreground"           Value="#D4D4D4"/>
      <Setter Property="BorderBrush"          Value="#3C3C3C"/>
      <Setter Property="RowBackground"        Value="#252526"/>
      <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
      <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
      <Setter Property="HeadersVisibility"    Value="Column"/>
      <Setter Property="SelectionMode"        Value="Single"/>
      <Setter Property="CanUserAddRows"       Value="False"/>
      <Setter Property="CanUserDeleteRows"    Value="False"/>
      <Setter Property="AutoGenerateColumns"  Value="False"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#2D2D2D"/>
      <Setter Property="Foreground" Value="#9CDCFE"/>
      <Setter Property="Padding"    Value="6,4"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="4,2"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#264F78"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- TabControl -->
    <Style TargetType="TabControl">
      <Setter Property="Background"  Value="#1E1E1E"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Background"  Value="#2D2D2D"/>
      <Setter Property="Foreground"  Value="#808080"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
      <Setter Property="Padding"     Value="10,4"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#1E1E1E"/>
          <Setter Property="Foreground" Value="#D4D4D4"/>
          <Setter Property="BorderBrush" Value="#007ACC"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#D4D4D4"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- GroupBox -->
    <Style TargetType="GroupBox">
      <Setter Property="Foreground"  Value="#9CDCFE"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
      <Setter Property="Margin"      Value="0,4"/>
    </Style>

    <!-- TreeView item template -->
    <HierarchicalDataTemplate x:Key="ObjTemplate"
        ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal"
                  Background="{Binding IsNeverCalled, Converter={StaticResource DeadColor}}">
        <Border CornerRadius="2" Padding="3,1" Margin="0,0,5,0"
                Background="{Binding IconColor, Converter={StaticResource StrToColor}}">
          <TextBlock Text="{Binding Icon}" Foreground="#1E1E1E"
                     FontSize="9" FontWeight="Bold"/>
        </Border>
        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
        <TextBlock Text=" ⚠" Foreground="#FF8C00" FontSize="10"
                   Visibility="{Binding IsNeverCalled, Converter={StaticResource BoolToVis}}"/>
        <TextBlock Text="{Binding LineInfo}" Foreground="#606060" FontSize="10"
                   Margin="8,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>
    </HierarchicalDataTemplate>
  </Window.Resources>

  <DockPanel>
    <!-- ═══ MENU ═══════════════════════════════════════════ -->
    <Menu DockPanel.Dock="Top" Background="DarkGreen" Foreground="#D4D4D4">
      <MenuItem Header="파일(_F)" Foreground="#D4D4D4">
        <MenuItem Header="파일 열기..." Click="MenuOpenFile" InputGestureText="Ctrl+O"/>
        <MenuItem Header="폴더 열기..." Click="MenuOpenFolder"/>
        <Separator/>
        <MenuItem Header="HTML 리포트 저장" Command="{Binding ExportCmd}"/>
        <Separator/>
        <MenuItem Header="종료" Click="MenuExit"/>
      </MenuItem>
      <MenuItem Header="편집(_E)" Foreground="#D4D4D4">
        <MenuItem Header="코드 포맷" Command="{Binding FormatCmd}" InputGestureText="Ctrl+Shift+F"/>
        <MenuItem Header="주석 제거" Command="{Binding NoCommentCmd}"/>
        <MenuItem Header="선택 소스 복사" Command="{Binding CopySourceCmd}"/>
        <Separator/>
        <MenuItem Header="찾기" Click="MenuFind" InputGestureText="Ctrl+F"/>
      </MenuItem>
      <MenuItem Header="분석(_A)" Foreground="#D4D4D4">
        <MenuItem Header="CRUD 매트릭스 빌드" Command="{Binding CrudCmd}"/>
        <MenuItem Header="Dead Code 표시" Click="MenuDeadCode"/>
      </MenuItem>
      <MenuItem Header="도움말(_H)" Foreground="#D4D4D4">
        <MenuItem Header="사용법" Click="MenuHelp"/>
      </MenuItem>
    </Menu>

    <!-- ═══ TOOLBAR ══════════════════════════════════════════ -->
    <ToolBar DockPanel.Dock="Top" Background="LightYellow"
             Foreground="#D4D4D4" ToolBarTray.IsLocked="True">
      <Button Click="MenuOpenFile" ToolTip="파일 열기 (Ctrl+O)">📂 파일 열기</Button>
      <Button Click="MenuOpenFolder" ToolTip="폴더의 모든 .sql 파일 열기">📁 폴더</Button>
      <Separator/>
      <Button Command="{Binding FormatCmd}" ToolTip="자동 들여쓰기 정렬 (Ctrl+Shift+F)">⚙ 포맷</Button>
      <Button Command="{Binding NoCommentCmd}" ToolTip="모든 주석 제거">✂ 주석제거</Button>
      <Separator/>
      <Button Command="{Binding CrudCmd}" ToolTip="CRUD 매트릭스 생성">📊 CRUD</Button>
      <Button Command="{Binding ExportCmd}" ToolTip="HTML 분석 리포트 저장">💾 HTML저장</Button>
      <Separator/>
      <TextBlock Text="검색:" VerticalAlignment="Center" Margin="4,0"/>
      <TextBox x:Name="TbSearch" Width="160" Margin="2,0"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="오브젝트 이름 검색"/>
    </ToolBar>

    <!-- ═══ STATUS ════════════════════════════════════════════ -->
    <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Foreground="White" Height="22">
      <StatusBarItem>
        <TextBlock Text="{Binding Status}" FontSize="11"/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem>
        <TextBlock x:Name="TbCaret" Text="L1 C1" FontSize="11"/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem>
        <TextBlock x:Name="TbFileCount" FontSize="11"/>
      </StatusBarItem>
    </StatusBar>

    <!-- ═══ MAIN GRID ═════════════════════════════════════════ -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" MinWidth="150"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"   MinWidth="300"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="380" MinWidth="200"/>
      </Grid.ColumnDefinitions>

      <!-- ─── LEFT PANEL ────────────────────────────────────── -->
      <Grid Grid.Column="0" Background="#252526">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <!-- Loaded files -->
        <Border Grid.Row="0" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="6,4">
          <TextBlock Text="📄 로드된 파일" Foreground="#9CDCFE" FontWeight="Bold" FontSize="11"/>
        </Border>
        <ListBox Grid.Row="0" x:Name="LbFiles" Margin="0,22,0,0" MaxHeight="90"
                 ItemsSource="{Binding Files}"
                 SelectionChanged="LbFiles_SelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding FileName}" FontSize="11"
                         ToolTip="{Binding FilePath}"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Object Tree -->
        <Border Grid.Row="1" BorderBrush="#3C3C3C" BorderThickness="0,1,0,1">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="🗂 오브젝트 트리" Foreground="#9CDCFE"
                       FontWeight="Bold" FontSize="11" Margin="6,4"/>
            <TreeView Grid.Row="1" x:Name="ObjTree"
                      ItemsSource="{Binding TreeRoots}"
                      ItemTemplate="{StaticResource ObjTemplate}"
                      SelectedItemChanged="ObjTree_SelectedItemChanged"
                      MouseDoubleClick="ObjTree_DoubleClick"
                      Background="#252526"/>
          </Grid>
        </Border>

        <!-- Search label -->
        <TextBlock Grid.Row="2" Text="🔍 오브젝트 검색 결과" Foreground="#9CDCFE"
                   FontWeight="Bold" FontSize="11" Margin="6,4"/>

        <!-- Search results -->
        <ListBox Grid.Row="3" x:Name="LbSearch"
                 ItemsSource="{Binding SearchResults}"
                 MouseDoubleClick="LbSearch_DoubleClick">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <Border CornerRadius="2" Padding="3,1" Margin="0,0,5,0"
                        Background="{Binding IconColor, Converter={StaticResource StrToColor}}">
                  <TextBlock Text="{Binding Icon}" Foreground="#1E1E1E" FontSize="9" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="{Binding Name}" FontSize="11"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                    Background="#3C3C3C" Cursor="SizeWE"/>

      <!-- ─── CENTER: EDITOR ─────────────────────────────────── -->
      <Grid Grid.Column="2" Background="#1E1E1E">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Editor header -->
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
          <StackPanel Orientation="Horizontal" Margin="6,3">
            <TextBlock x:Name="TbEditorTitle" Text="📝 코드 에디터"
                       Foreground="#9CDCFE" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="  (파일 드래그+드롭 가능)" Foreground="#606060" FontSize="10" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- AvalonEdit -->
        <ae:TextEditor Grid.Row="1" x:Name="Editor"
            FontFamily="Consolas" FontSize="13"
            Background="#1E1E1E" Foreground="#D4D4D4"
            ShowLineNumbers="True"
            LineNumbersForeground="#858585"
            WordWrap="False"/>

        <!-- Find bar -->
        <Border Grid.Row="2" x:Name="FindBar" Visibility="Collapsed"
                Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="6,4">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="찾기:" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="TbFindText" Width="200" Margin="0,0,4,0"
                     KeyDown="TbFindText_KeyDown"/>
            <CheckBox x:Name="CbMatchCase" Content="대소문자 구분" Foreground="#D4D4D4"
                      VerticalAlignment="Center" Margin="6,0"/>
            <CheckBox x:Name="CbRegex"     Content="정규식"       Foreground="#D4D4D4"
                      VerticalAlignment="Center" Margin="6,0"/>
            <Button Click="FindPrev"  Margin="4,0" Padding="6,2">◀ 이전</Button>
            <Button Click="FindNext"  Margin="4,0" Padding="6,2">다음 ▶</Button>
            <Button Click="FindClose" Margin="8,0" Padding="6,2" Foreground="#FF6060">✕</Button>
            <TextBlock x:Name="TbFindStatus" Foreground="#808080" Margin="10,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                    Background="#3C3C3C" Cursor="SizeWE"/>

      <!-- ─── RIGHT PANEL: ANALYSIS ─────────────────────────── -->
      <TabControl Grid.Column="4" Background="#1E1E1E">

        <!-- ── Parameters tab ── -->
        <TabItem Header="⬡ 파라미터">
          <Grid Background="#1E1E1E">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#252526" Padding="6,4"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
              <TextBlock x:Name="TbParamHeader" Text="파라미터" Foreground="#9CDCFE" FontWeight="Bold"/>
            </Border>
            <DataGrid Grid.Row="1" x:Name="DgParams"
                      ItemsSource="{Binding SelParams}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="이름"       Binding="{Binding Name}"    Width="100"/>
                <DataGridTextColumn Header="방향"       Binding="{Binding Dir}"     Width="60"/>
                <DataGridTextColumn Header="타입"       Binding="{Binding DataType}" Width="*"/>
                <DataGridTextColumn Header="기본값"     Binding="{Binding Default}" Width="80"/>
                <DataGridTextColumn Header="라인"       Binding="{Binding Line}"    Width="50"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- ── SQL tab ── -->
        <TabItem Header="📋 SQL 쿼리">
          <Grid Background="#1E1E1E">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="180"/>
              <RowDefinition Height="4"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#252526" Padding="6,4"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
              <TextBlock Text="SQL 쿼리 목록 (선택하면 상세보기)" Foreground="#9CDCFE" FontWeight="Bold"/>
            </Border>
            <DataGrid Grid.Row="1" x:Name="DgSqls"
                      ItemsSource="{Binding SelSqls}"
                      SelectionChanged="DgSqls_SelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="종류"   Binding="{Binding Kind}"         Width="60"/>
                <DataGridTextColumn Header="테이블" Binding="{Binding Tables[0]}"    Width="*"/>
                <DataGridTextColumn Header="컬럼수" Binding="{Binding Columns.Count}" Width="50"/>
                <DataGridTextColumn Header="서브Q"  Binding="{Binding FromSubqueries.Count}" Width="50"/>
                <DataGridTextColumn Header="라인"   Binding="{Binding StartLine}"    Width="50"/>
              </DataGrid.Columns>
            </DataGrid>
            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#3C3C3C"/>
            <Grid Grid.Row="3">
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <!-- Columns -->
              <GroupBox Grid.Row="0" Header="SELECT 컬럼 목록" Margin="4,4,4,2">
                <ListBox x:Name="LbSqlCols" FontSize="11" FontFamily="Consolas">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Display}"
                                 Foreground="{Binding IsSubquery, Converter={StaticResource BoolToVis}, ConverterParameter='#FF8C00'}"
                                 FontStyle="{Binding IsSubquery, Converter={StaticResource BoolToVis}}"/>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </GroupBox>
              <!-- Raw SQL -->
              <GroupBox Grid.Row="1" Header="원본 SQL" Margin="4,2,4,4">
                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                  <TextBlock x:Name="TbRawSql" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="11"
                             Foreground="#CE9178" Margin="2"/>
                </ScrollViewer>
              </GroupBox>
            </Grid>
          </Grid>
        </TabItem>

        <!-- ── Calls tab ── -->
        <TabItem Header="🔗 호출">
          <Grid Background="#1E1E1E">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#252526" Padding="6,4"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
              <TextBlock Text="호출 목록 (더블클릭 → 정의로 이동)" Foreground="#9CDCFE" FontWeight="Bold"/>
            </Border>
            <DataGrid Grid.Row="1" x:Name="DgCalls"
                      ItemsSource="{Binding SelCalls}"
                      MouseDoubleClick="DgCalls_DoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="라인"   Binding="{Binding Line}"    Width="55"/>
                <DataGridTextColumn Header="패키지" Binding="{Binding PkgName}" Width="90"/>
                <DataGridTextColumn Header="이름"   Binding="{Binding Name}"    Width="*"/>
                <DataGridTemplateColumn Header="상태" Width="40">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Status}"
                                 Foreground="{Binding Target, Converter={StaticResource CallColor}}"
                                 FontWeight="Bold" HorizontalAlignment="Center"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- ── Variables tab ── -->
        <TabItem Header="📌 변수">
          <Grid Background="#1E1E1E">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#252526" Padding="6,4"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
              <TextBlock Text="선언 변수  (노란 배경 = 미사용 가능성)" Foreground="#9CDCFE" FontWeight="Bold"/>
            </Border>
            <DataGrid Grid.Row="1" x:Name="DgVars"
                      ItemsSource="{Binding SelVars}">
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Setter Property="Background"
                          Value="{Binding IsUsed, Converter={StaticResource UnusedColor}}"/>
                </Style>
              </DataGrid.RowStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="이름"   Binding="{Binding Name}"    Width="120"/>
                <DataGridTextColumn Header="종류"   Binding="{Binding Kind}"    Width="70"/>
                <DataGridTextColumn Header="타입"   Binding="{Binding DataType}" Width="*"/>
                <DataGridTextColumn Header="기본값" Binding="{Binding Default}" Width="80"/>
                <DataGridTextColumn Header="라인"   Binding="{Binding Line}"    Width="50"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- ── Metrics tab ── -->
        <TabItem Header="📈 메트릭스">
          <ScrollViewer Background="#1E1E1E" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12" DataContext="{Binding SelMetrics}">
              <TextBlock Text="코드 메트릭스" Foreground="#9CDCFE"
                         FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

              <TextBlock Visibility="{Binding DataContext.SelectedObject.IsNeverCalled,
                         RelativeSource={RelativeSource AncestorType=ScrollViewer},
                         Converter={StaticResource BoolToVis}}"
                         Text="⚠ 이 오브젝트는 다른 곳에서 호출되지 않습니다 (Dead Code 가능성)"
                         Foreground="#FF8C00" FontWeight="Bold" Margin="0,0,0,10"
                         TextWrapping="Wrap"/>

              <Grid x:Name="MetricsGrid">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="150"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                  <RowDefinition Height="28"/>
                </Grid.RowDefinitions>
              </Grid>

              <!-- Manual metric rows for binding clarity -->
              <Border Background="#252526" CornerRadius="4" Padding="12" Margin="0,4">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="전체 라인수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding Total}" Foreground="#4EC9B0" FontWeight="Bold"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="코드 라인수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding Code}" Foreground="#4EC9B0" FontWeight="Bold"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="주석 라인수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding Comments}" Foreground="#608B4E" FontWeight="Bold"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="빈 라인수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding Blank}" Foreground="#606060" FontWeight="Bold"/>
                  </StackPanel>
                  <Separator Background="#3C3C3C" Margin="0,6"/>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="순환 복잡도 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding ComplexityLabel}" FontWeight="Bold">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="#4EC9B0"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Complexity}" Value="0">
                              <Setter Property="Foreground" Value="#4EC9B0"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="최대 중첩 깊이 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding MaxNesting}" Foreground="#B5CEA8" FontWeight="Bold"/>
                  </StackPanel>
                  <Separator Background="#3C3C3C" Margin="0,6"/>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="파라미터 수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding ParamLabel}" FontWeight="Bold" Foreground="#9CDCFE"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="SQL 쿼리 수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding SqlCount}" Foreground="#C586C0" FontWeight="Bold"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="외부 호출 수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding CallCount}" Foreground="#569CD6" FontWeight="Bold"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="선언 변수 수 :" Foreground="#808080" Width="130"/>
                    <TextBlock Text="{Binding VarCount}" Foreground="#D4D4D4" FontWeight="Bold"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- ── CRUD tab ── -->
        <TabItem Header="🗃 CRUD">
          <Grid Background="#1E1E1E">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#252526" Padding="6,4"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="CRUD 매트릭스 — " Foreground="#9CDCFE" FontWeight="Bold"/>
                <Button Padding="6,2" Command="{Binding CrudCmd}">빌드 ▶</Button>
              </StackPanel>
            </Border>
            <DataGrid Grid.Row="1" ItemsSource="{Binding CrudMatrix}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="오브젝트" Binding="{Binding FullName}" Width="140"/>
                <DataGridTextColumn Header="SELECT"  Binding="{Binding SelectStr}" Width="*"/>
                <DataGridTextColumn Header="INSERT"  Binding="{Binding InsertStr}" Width="*"/>
                <DataGridTextColumn Header="UPDATE"  Binding="{Binding UpdateStr}" Width="*"/>
                <DataGridTextColumn Header="DELETE"  Binding="{Binding DeleteStr}" Width="*"/>
                <DataGridTextColumn Header="MERGE"   Binding="{Binding MergeStr}"  Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- ── Format options ── -->
        <TabItem Header="⚙ 포맷">
          <ScrollViewer Background="#1E1E1E">
            <StackPanel Margin="12" DataContext="{Binding FormOpts}">
              <TextBlock Text="포맷 옵션" Foreground="#9CDCFE" FontWeight="Bold" FontSize="13" Margin="0,0,0,12"/>
              <StackPanel Orientation="Horizontal" Margin="0,6">
                <TextBlock Text="들여쓰기 크기:" Foreground="#808080" Width="130" VerticalAlignment="Center"/>
                <Slider x:Name="SlIndent" Width="120" Minimum="2" Maximum="8"
                        Value="{Binding IndentSize}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                <TextBlock Text="{Binding IndentSize}" Margin="8,0" Foreground="#4EC9B0" VerticalAlignment="Center"/>
              </StackPanel>
              <CheckBox Content="포맷 시 주석 제거" IsChecked="{Binding RemoveAllComments}"
                        Foreground="#D4D4D4" Margin="0,8"/>
              <Separator Background="#3C3C3C" Margin="0,12"/>
              <Button Command="{Binding FormatCmd}" Padding="10,5" HorizontalAlignment="Left">
                ▶ 지금 포맷 적용
              </Button>
              <Button Command="{Binding NoCommentCmd}" Padding="10,5"
                      HorizontalAlignment="Left" Margin="0,6">
                ✂ 지금 주석 제거
              </Button>
              <Separator Background="#3C3C3C" Margin="0,12"/>
              <Border Background="#252526" CornerRadius="4" Padding="10">
                <StackPanel>
                  <TextBlock Text="사용법 가이드" Foreground="#9CDCFE" FontWeight="Bold" Margin="0,0,0,8"/>
                  <TextBlock TextWrapping="Wrap" Foreground="#808080" FontSize="11" LineHeight="18">
                    • 파일 열기 또는 .sql 파일 드래그+드롭&#10;
                    • 왼쪽 트리에서 프로시저/함수 클릭 → 에디터 이동&#10;
                    • 호출 탭 더블클릭 → 정의로 이동&#10;
                    • CRUD 탭 → [빌드] 클릭으로 테이블 사용 현황 확인&#10;
                    • ⚠ 표시 = Dead Code 가능성 (호출 없음)&#10;
                    • 노란 배경 변수 = 미사용 가능성&#10;
                    • Ctrl+F = 에디터 내 검색&#10;
                    • Ctrl+Shift+F = 코드 포맷
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

      </TabControl>
    </Grid>
  </DockPanel>
</Window>
